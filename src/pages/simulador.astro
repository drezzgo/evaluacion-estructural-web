---
/**
 * simulador.astro
 * Página del simulador 3D educativo de fallas estructurales en muros.
 * Ahora integrada como página interna de la web principal.
 */

import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { WallSimulatorApp } from '../features/wall-simulator/components/WallSimulatorApp.tsx';
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead 
    title={`Simulador Estructural | ${SITE_TITLE}`} 
    description="Simulador educativo de fallas estructurales en muros. Visualiza en tiempo real cómo el material, las dimensiones y las cargas afectan la integridad de un muro." 
  />
  <meta name="robots" content="noindex" />
</head>
<body class="antialiased bg-[#fbfdfd] text-brand-charcoal min-h-screen flex flex-col">
  <Header />
  
  <main class="flex-1 w-full max-w-[1400px] mx-auto px-4 py-8 md:py-12 flex flex-col gap-6">
    {/* Encabezado del simulador */}
    <div class="text-center max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-ea-blue bg-ea-blue/5 border border-ea-blue/10 rounded-full mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-ea-blue animate-pulse"></span>
        Herramienta Educativa Interactiva
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-brand-midnight font-display mb-4">
        Simulador de Muros
      </h1>
      <p class="text-gray-500 text-sm md:text-base font-light">
        Ajusta dimensiones, materiales y cargas para observar el comportamiento estructural.
        <br/><span class="font-medium text-ea-blue/80 text-xs">Simulación teórica con fines demostrativos.</span>
      </p>
    </div>

    {/* Contenedor principal de la App React */}
    <div class="w-full bg-white rounded-2xl cal-shadow overflow-hidden border border-gray-100 flex flex-col" style="height: 75vh; min-height: 550px; max-height: 800px;">
      <WallSimulatorApp client:only="react" />
    </div>
  </main>

  <Footer />
</body>
</html>
