---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const servicios = (await getCollection('servicios')).sort(
	(a, b) => a.data.order - b.data.order
);

const icons = {
	"shield-check": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>`,
	"microscope": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18h8"></path><path d="M3 22h18"></path><path d="M14 22a7 7 0 1 0 0-14h-1"></path><path d="M9 14h2"></path><path d="M9 12a2 2 0 1 1-2-2V6h6v4.1"></path><path d="M12 6V3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3"></path></svg>`,
	"wrench": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>`,
	"test-tube": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2v17.5c0 1.4-1.1 2.5-2.5 2.5h0c-1.4 0-2.5-1.1-2.5-2.5V2"></path><path d="M8.5 2h7"></path><path d="M14.5 16h-5"></path></svg>`,
	"layout": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>`,
	"file-text": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14.5 2 14.5 7.5 20 7.5"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><line x1="10" y1="9" x2="8" y2="9"></line></svg>`,
	"ruler": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.3 15.3 4.4 2.6l-1.8 1.8 12.7 16.9c.8.8 2 .8 2.8 0l3.2-3.2c.8-.8.8-2 0-2.8Z"></path><path d="m7.5 10.3 1.4-1.4"></path><path d="m10.5 12.8 1.4-1.4"></path><path d="m13.5 15.3 1.4-1.4"></path><path d="m16.5 17.8 1.4-1.4"></path></svg>`,
	"briefcase": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>`
};
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Servicios | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-gray-50">
		<Header />
		<main class="mx-auto max-w-[1200px] px-6 py-12 md:px-12 md:py-20">
			<div class="mb-16 text-center">
				<h1 class="text-4xl md:text-5xl font-bold text-[#111111] mb-6 tracking-tight">
					Nuestros Servicios
				</h1>
				<p class="text-lg text-gray-600 max-w-2xl mx-auto">
					Soluciones especializadas en ingeniería estructural, diagnóstico y consultoría técnica bajo normativa NSR-10.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
				{servicios.map((servicio) => {
					const iconKey = (servicio.data.icon ?? 'file-text') as keyof typeof icons;
					const iconSvg = icons[iconKey] ?? icons['file-text'];
					return (
					<a 
						href={`/servicios/${servicio.id}/`}
						class="group bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 no-underline"
					>
						<div class="w-12 h-12 rounded-xl bg-gray-50 flex items-center justify-center text-[#242424] mb-6 group-hover:bg-[#242424] group-hover:text-white transition-colors">
							<Fragment set:html={iconSvg} />
						</div>
						<h3 class="text-xl font-bold text-[#111111] mb-3 group-hover:text-[#242424]">
							{servicio.data.title}
						</h3>
						<p class="text-gray-500 text-sm leading-relaxed mb-6">
							{servicio.data.description}
						</p>
						<span class="text-[13px] font-semibold text-[#242424] flex items-center gap-2">
							Leer más 
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
						</span>
					</a>
				);
				})}
			</div>

			<!-- Banner de contacto -->
			<section class="mt-24 bg-[#242424] rounded-3xl p-8 md:p-16 text-center text-white">
				<h2 class="text-3xl md:text-4xl font-bold mb-6">¿Necesitas un diagnóstico especializado?</h2>
				<p class="text-gray-400 mb-8 max-w-xl mx-auto">Nuestro equipo técnico está listo para asesorarte en la seguridad y estabilidad de tu infraestructura.</p>
				<a href="/contacto" class="inline-flex bg-white text-[#242424] px-8 py-4 rounded-full font-bold hover:bg-gray-100 transition-colors no-underline">
					Contactar con un experto
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
