---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTASection from '../components/CTASection.astro';

const services = [
  {
    id: 'inspeccion',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 20h20M6 20V10m4 10V4m4 16v-6m4 6v-8"/></svg>`,
    title: 'Inspección Estructural',
    description:
      'Realizamos inspecciones técnicas detalladas de edificaciones, puentes, muros de contención, estructuras industriales y obras civiles. Identificamos daños visibles, deterioro de materiales, humedad, fisuras, asentamientos y otros indicadores de comportamiento estructural inadecuado. El proceso incluye visita de campo, registro fotográfico, toma de muestras y elaboración de informe técnico.',
  },
  {
    id: 'diagnostico',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    title: 'Diagnóstico Patológico',
    description:
      'Determinamos el origen y causas de las patologías estructurales detectadas. El diagnóstico incluye análisis de las condiciones del terreno, del proceso constructivo, del comportamiento de materiales y de las cargas actuantes. Como resultado entregamos un informe de patologías con recomendaciones de intervención técnicamente sustentadas.',
  },
  {
    id: 'rehabilitacion',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    title: 'Rehabilitación Estructural',
    description:
      'Diseñamos y supervisamos las intervenciones de reparación y rehabilitación de estructuras con daños o deterioro. Abarcamos desde la reparación de fisuras y protección superficial, hasta la recuperación de capacidad portante mediante refuerzo estructural. Trabajamos con metodologías validadas y materiales de alta calidad.',
  },
  {
    id: 'consultoria',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Consultoría Técnica',
    description:
      'Brindamos asesoría especializada en ingeniería estructural para proyectos en diseño o ejecución. Revisamos planos estructurales, verificamos el cumplimiento de las normas NSR-10, emitimos conceptos técnicos y acompañamos a propietarios, constructores y entidades durante el ciclo de vida del proyecto.',
  },
  {
    id: 'refuerzo',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><path d="M14 17h7M17 14v7"/></svg>`,
    title: 'Refuerzo Estructural',
    description:
      'Implementamos soluciones de refuerzo estructural con fibra de carbono (FRP), acero estructural, encamisados en concreto, platinas metálicas y otros sistemas. Cada solución es diseñada y calculada por ingenieros competentes, y se documenta con planos de intervención y memorias de cálculo.',
  },
  {
    id: 'peritajes',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'Peritajes y Dictámenes',
    description:
      'Elaboramos informes periciales para procesos judiciales, disputas contractuales, reclamaciones ante aseguradoras y requerimientos institucionales. Nuestros dictámenes son firmados por ingenieros con matrícula profesional vigente ante el COPNIA y están respaldados por evidencia técnica verificable.',
  },
];
---

<BaseLayout
  title="Servicios"
  description="Portafolio de servicios de Evaluación Estructural SAS: inspección, diagnóstico, rehabilitación, consultoría, refuerzo y peritajes estructurales."
>
  <!-- Page Hero -->
  <section class="page-hero section--dark section">
    <div class="container">
      <span class="section-label">Portafolio de servicios</span>
      <h1 class="section-title" style="color: white;">Servicios de ingeniería estructural</h1>
      <p class="section-subtitle">
        Un portafolio integral para acompañar sus proyectos desde la inspección
        hasta la rehabilitación, con respaldo técnico y normativo.
      </p>
    </div>
  </section>

  <!-- Services list -->
  <section class="section">
    <div class="container">
      <div class="services-list">
        {services.map((s) => (
          <article id={s.id} class="service-detail">
            <div class="service-detail__icon" aria-hidden="true">
              <Fragment set:html={s.icon} />
            </div>
            <div class="service-detail__body">
              <h2 class="service-detail__title">{s.title}</h2>
              <p class="service-detail__text">{s.description}</p>
              <a href="/contacto" class="service-detail__cta">
                Solicitar este servicio
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <polyline points="9 18 15 12 9 6"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="¿Su proyecto no encaja exactamente en estos servicios?"
    subtitle="Cuéntenos su caso. Evaluamos cada situación de forma personalizada y proponemos la solución más adecuada."
  />
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-16);
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .service-detail {
    display: flex;
    gap: var(--space-8);
    padding: var(--space-10);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .service-detail:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
  }

  .service-detail__icon {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    width: 56px;
    height: 56px;
    background-color: rgba(13, 45, 79, 0.07);
    border-radius: var(--radius-md);
    color: var(--color-primary);
    flex-shrink: 0;
    padding: 14px;
  }

  .service-detail__body {
    flex: 1;
  }

  .service-detail__title {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .service-detail__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }

  .service-detail__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-accent);
    text-decoration: none;
    transition: gap var(--transition);
  }

  .service-detail__cta:hover {
    gap: var(--space-2);
  }

  @media (max-width: 600px) {
    .service-detail {
      flex-direction: column;
      padding: var(--space-6);
    }
  }
</style>
