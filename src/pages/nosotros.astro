---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import Button from '../components/Button.astro';

const values = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Rigor técnico',
    description: 'Aplicamos metodologías comprobadas y normas vigentes NSR-10 en cada evaluación y diagnóstico.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    title: 'Cumplimiento normativo',
    description: 'Garantizamos el cumplimiento de toda la normativa técnica vigente en Colombia para cada tipo de intervención.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Equipo calificado',
    description: 'Contamos con ingenieros civiles, especialistas y técnicos con matrícula profesional vigente y amplia experiencia.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
    title: 'Compromiso con resultados',
    description: 'Nuestros informes son claros, precisos y accionables, orientados a la toma de decisiones técnicas fundamentadas.',
  },
];

const team = [
  {
    name: 'Ing. Carlos Rodríguez, MSc.',
    initial: 'C',
    role: 'Director Técnico — Matrícula COPNIA',
    bio: 'Ingeniero civil con especialización en estructuras y maestría en ingeniería estructural. Más de 20 años de experiencia en evaluación y rehabilitación de edificaciones.',
  },
  {
    name: 'Ing. Sandra Morales',
    initial: 'S',
    role: 'Especialista en Patología Estructural',
    bio: 'Especialista en durabilidad y rehabilitación de estructuras de concreto. Ha liderado proyectos de intervención en más de 200 edificaciones en Colombia.',
  },
  {
    name: 'Ing. Andrés Castillo',
    initial: 'A',
    role: 'Ingeniero de Refuerzo Estructural',
    bio: 'Experto en sistemas de refuerzo con FRP, encamisados y soluciones metálicas. Coordinador de proyectos industriales y hospitalarios.',
  },
];
---

<BaseLayout
  title="Nosotros"
  description="Conozca Evaluación Estructural SAS: quiénes somos, nuestra misión, valores y el equipo de ingenieros que respalda cada proyecto."
>
  <!-- Hero -->
  <section class="page-hero section--dark section">
    <div class="container">
      <span class="section-label">Quiénes somos</span>
      <h1 class="section-title" style="color: white;">Una firma de confianza para sus proyectos estructurales</h1>
      <p class="section-subtitle">
        Más de dos décadas de experiencia, profesionales certificados y un compromiso
        permanente con la calidad técnica y la seguridad estructural.
      </p>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="section">
    <div class="container mv-grid">
      <div class="mv-card">
        <span class="section-label">Misión</span>
        <h2 class="mv-card__title">Proteger estructuras, respaldar decisiones</h2>
        <p class="mv-card__text">
          Brindar servicios de evaluación e ingeniería estructural con la más alta calidad técnica,
          apoyando a propietarios, constructores e instituciones en la toma de decisiones seguras,
          informadas y técnicamente sustentadas sobre el estado y mantenimiento de sus estructuras.
        </p>
      </div>
      <div class="mv-card mv-card--accent">
        <span class="section-label" style="color: var(--color-accent);">Visión</span>
        <h2 class="mv-card__title" style="color: white;">Ser referente nacional en ingeniería forense estructural</h2>
        <p class="mv-card__text" style="color: rgba(255,255,255,0.72);">
          Consolidarnos como la firma líder en Colombia en evaluación e ingeniería estructural,
          reconocida por su rigor técnico, su independencia profesional y su capacidad para
          resolver los desafíos más complejos del sector de la construcción.
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section section--soft">
    <div class="container">
      <header class="values__header">
        <span class="section-label">Nuestros valores</span>
        <h2 class="section-title">Principios que guían cada proyecto</h2>
        <hr class="divider" />
      </header>
      <div class="grid-2">
        {values.map((v) => (
          <div class="value-item">
            <div class="value-item__icon" aria-hidden="true">
              <Fragment set:html={v.icon} />
            </div>
            <div>
              <h3 class="value-item__title">{v.title}</h3>
              <p class="value-item__text">{v.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container">
      <header class="team__header">
        <span class="section-label">Nuestro equipo</span>
        <h2 class="section-title">Los ingenieros detrás de cada proyecto</h2>
        <hr class="divider" />
        <p class="section-subtitle">
          Profesionales con matrícula vigente ante el COPNIA y experiencia comprobada
          en los sectores residencial, comercial, industrial e institucional.
        </p>
      </header>

      <div class="grid-3">
        {team.map((member) => (
          <div class="team-card">
            <div class="team-card__avatar" aria-hidden="true">
              {member.initial}
            </div>
            <h3 class="team-card__name">{member.name}</h3>
            <span class="team-card__role">{member.role}</span>
            <p class="team-card__bio">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-16);
  }

  /* Mission / Vision */
  .mv-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .mv-grid { grid-template-columns: 1fr 1fr; }
  }

  .mv-card {
    padding: var(--space-10);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .mv-card--accent {
    background-color: var(--color-primary);
    border-color: transparent;
  }

  .mv-card__title {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
    margin-top: var(--space-3);
  }

  .mv-card--accent .mv-card__title {
    color: var(--color-text-light);
  }

  .mv-card__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* Values */
  .values__header {
    max-width: 560px;
    margin-bottom: var(--space-12);
  }

  .value-item {
    display: flex;
    gap: var(--space-5);
    align-items: flex-start;
  }

  .value-item__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background-color: rgba(13, 45, 79, 0.07);
    border-radius: var(--radius-md);
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .value-item__title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .value-item__text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* Team */
  .team__header {
    max-width: 600px;
    margin-bottom: var(--space-12);
  }

  .team-card {
    padding: var(--space-8);
    background-color: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .team-card__avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background-color: var(--color-primary);
    color: var(--color-accent);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    border-radius: 50%;
    margin-bottom: var(--space-2);
  }

  .team-card__name {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
  }

  .team-card__role {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
  }

  .team-card__bio {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }
</style>
