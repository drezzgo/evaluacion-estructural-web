---
import ServiceCard from './ServiceCard.astro';
import Button from './Button.astro';

const services = [
  {
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 20h20M6 20V10m4 10V4m4 16v-6m4 6v-8"/></svg>`,
    title: 'Inspección Estructural',
    description:
      'Evaluación detallada de edificaciones, puentes y obras civiles para determinar el estado técnico de la estructura, identificar daños y registrar patologías.',
    href: '/servicios#inspeccion',
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    title: 'Diagnóstico Patológico',
    description:
      'Análisis técnico de las causas y origen de las lesiones estructurales, con elaboración de informe de patologías y recomendaciones de intervención.',
    href: '/servicios#diagnostico',
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    title: 'Rehabilitación Estructural',
    description:
      'Diseño y supervisión de intervenciones de reparación, refuerzo y recuperación de capacidad portante en estructuras deterioradas o dañadas.',
    href: '/servicios#rehabilitacion',
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Consultoría Técnica',
    description:
      'Asesoría especializada para proyectos nuevos o en ejecución, revisión de diseños estructurales, conceptos técnicos y acompañamiento profesional.',
    href: '/servicios#consultoria',
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><path d="M14 17h7M17 14v7"/></svg>`,
    title: 'Refuerzo Estructural',
    description:
      'Implementación de soluciones de refuerzo con fibra de carbono (FRP), acero estructural, encamisados y otros sistemas validados técnicamente.',
    href: '/servicios#refuerzo',
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'Peritajes y Dictámenes',
    description:
      'Elaboración de informes periciales para procesos judiciales, aseguradoras e instituciones, con firma de ingeniero matriculado ante el COPNIA.',
    href: '/servicios#peritajes',
  },
];
---

<section class="section section--soft">
  <div class="container">
    <header class="services__header">
      <span class="section-label">Nuestros servicios</span>
      <h2 class="section-title">Soluciones técnicas para cada desafío estructural</h2>
      <hr class="divider" />
      <p class="section-subtitle">
        Ofrecemos un portafolio integral de servicios de ingeniería estructural,
        respaldados por profesionales con matrícula COPNIA y experiencia en todo el territorio nacional.
      </p>
    </header>

    <div class="grid-3">
      {services.map((s) => (
        <ServiceCard
          icon={s.icon}
          title={s.title}
          description={s.description}
          href={s.href}
        />
      ))}
    </div>

    <div class="services__footer">
      <Button href="/servicios" variant="secondary" size="md">
        Ver todos los servicios
      </Button>
    </div>
  </div>
</section>

<style>
  .services__header {
    max-width: 680px;
    margin-bottom: var(--space-12);
  }

  .services__footer {
    margin-top: var(--space-12);
    text-align: center;
  }
</style>
