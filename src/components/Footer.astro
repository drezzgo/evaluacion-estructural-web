---
const navLinks = [
  { href: '/',           label: 'Inicio'    },
  { href: '/servicios',  label: 'Servicios'  },
  { href: '/nosotros',   label: 'Nosotros'   },
  { href: '/contacto',   label: 'Contacto'   },
];

const services = [
  'Inspección Estructural',
  'Diagnóstico Patológico',
  'Rehabilitación Estructural',
  'Consultoría Técnica',
  'Refuerzo Estructural',
  'Peritajes y Dictámenes',
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__grid">
    <!-- Brand -->
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Evaluación Estructural SAS">
        <span class="footer__logo-mark">E</span>
        <span class="footer__logo-text">
          Evaluación<br /><strong>Estructural SAS</strong>
        </span>
      </a>
      <p class="footer__tagline">
        Ingeniería estructural de confianza. Inspeccionamos, diagnosticamos
        y rehabilitamos estructuras con rigor técnico y compromiso profesional.
      </p>
    </div>

    <!-- Navigation -->
    <div class="footer__col">
      <h3 class="footer__heading">Navegación</h3>
      <ul class="footer__list">
        {navLinks.map(({ href, label }) => (
          <li><a href={href} class="footer__link">{label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Services -->
    <div class="footer__col">
      <h3 class="footer__heading">Servicios</h3>
      <ul class="footer__list">
        {services.map((s) => (
          <li><a href="/servicios" class="footer__link">{s}</a></li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div class="footer__col">
      <h3 class="footer__heading">Contacto</h3>
      <ul class="footer__contact-list">
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span>Bogotá D.C., Colombia</span>
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.69 3.4 2 2 0 0 1 3.68 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"/>
          </svg>
          <a href="tel:+573001234567" class="footer__link">+57 300 123 4567</a>
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <a href="mailto:info@evaluacionestructural.com.co" class="footer__link">
            info@evaluacionestructural.com.co
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">
        &copy; {year} Evaluación Estructural SAS. Todos los derechos reservados.
      </p>
      <p class="footer__legal">
        NIT: 901.XXX.XXX-X &nbsp;|&nbsp; Matrícula profesional COPNIA
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary);
    color: rgba(255, 255, 255, 0.75);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    padding-block: var(--space-16);
  }

  @media (min-width: 640px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer__grid {
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
      gap: var(--space-12);
    }
  }

  /* Brand */
  .footer__logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    text-decoration: none;
  }

  .footer__logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: var(--color-accent);
    color: var(--color-primary);
    font-size: 1.25rem;
    font-weight: var(--font-bold);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .footer__logo-text {
    font-size: var(--text-sm);
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.8);
  }

  .footer__logo-text strong {
    display: block;
    color: var(--color-text-light);
    font-size: var(--text-base);
    font-weight: var(--font-bold);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
    max-width: 300px;
  }

  /* Columns */
  .footer__heading {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-5);
  }

  .footer__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
  }

  .footer__link {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__link:hover {
    color: var(--color-text-light);
  }

  /* Contact list */
  .footer__contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    list-style: none;
  }

  .footer__contact-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.65);
  }

  .footer__contact-list svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-accent);
  }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-block: var(--space-6);
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer__copy,
  .footer__legal {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.45);
  }
</style>
